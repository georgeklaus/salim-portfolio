DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Contact email. For Gmail, use an App Password, not your normal password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=alfredsalimodhiambo@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_TIMEOUT=5
DEFAULT_FROM_EMAIL=alfredsalimodhiambo@gmail.com
CONTACT_RECIPIENT_EMAIL=alfredsalimodhiambo@gmail.com

# Render-friendly HTTPS email option. If set, this is used instead of SMTP.
RESEND_API_KEY=re_your_api_key
# For first tests without a verified domain, Resend allows its test sender.
# DEFAULT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
